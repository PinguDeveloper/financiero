# Hostinger (Apache): rotas do Next export com trailingSlash
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Arquivos reais (JS, CSS, sw.js, manifest, ícones)
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # Pastas com index.html (ex.: /app/, /login/)
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # /app -> /app/
  RewriteCond %{REQUEST_URI} !/$
  RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}/index.html -f
  RewriteRule ^(.*)$ $1/ [R=301,L]
</IfModule>

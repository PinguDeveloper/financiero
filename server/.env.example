# PostgreSQL (padrão recomendado). Suba o container na raiz: `npm run docker:db`
# Depois: `npm run db:migrate` (aplica migrações) ou `npm run db:migrate:dev` (cria novas em dev).
DATABASE_URL="postgresql://finance:finance@127.0.0.1:5432/controle_financeiro?schema=public"

# SQLite (legado — só um dos dois DATABASE_URL deve estar ativo)
# DATABASE_URL="file:./prisma/dev.db"

JWT_SECRET="troque-por-uma-string-longa-e-aleatoria"# Uma ou várias origens separadas por vírgula (front na Vercel + testes locais)
CLIENT_ORIGIN="http://localhost:5180,http://127.0.0.1:5180,http://localhost:5173,http://127.0.0.1:5173,http://localhost:4000,http://127.0.0.1:4000"
# Opcional: 1 = aceita qualquer *.vercel.app (útil em previews da Vercel)
ALLOW_VERCEL_PREVIEWS=""
PORT=4000
# Opcional: token em https://brapi.dev (cotações B3)
BRAPI_TOKEN=""
# URL pública do front (Vercel) — usada no link do e-mail de redefinição de senha
APP_PUBLIC_URL="http://127.0.0.1:5180"
# E-mail (Resend — https://resend.com): obrigatório em produção para "esqueci a senha"
RESEND_API_KEY=""
# Remetente (domínio verificado na Resend). Teste: onboarding@resend.dev
EMAIL_FROM="Controle Financeiro <onboarding@resend.dev>"
# Minutos do teste grátis após cadastro verificado
TRIAL_MINUTES=10
# Assinatura: manual (PIX + código) é o padrão. Use stripe só se quiser cartão.
SUBSCRIPTION_MODE=manual
MANUAL_PLAN_PRICE=5
MANUAL_PLAN_DAYS=30
PIX_KEY=""
PIX_RECIPIENT_NAME="Atlas Invest"
SUBSCRIPTION_CONTACT_URL=""
# Códigos de uso único: CODIGO1:30,CODIGO2:30 (dias de acesso)
SUBSCRIPTION_VOUCHERS=""
# Para liberar manualmente: POST /api/billing/admin/activate com header x-admin-key
# Enviar código por e-mail após PIX: POST /api/billing/admin/send-code { "email": "..." }
ADMIN_API_KEY=""
# Obrigatório para fluxo PIX: seu e-mail recebe link "Aprovar e enviar código" quando o cliente clica "Já fiz o PIX"
BILLING_ADMIN_NOTIFY_EMAIL=""
# Cidade no QR PIX (máx. 15 caracteres, sem acento)
PIX_CITY="BRASILIA"
# Stripe (opcional — só com SUBSCRIPTION_MODE=stripe)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_MONTHLY_PRICE=5
# Em produção monólito: pasta do build do Vite (relativo à pasta server/)
CLIENT_DIST="../client/dist"

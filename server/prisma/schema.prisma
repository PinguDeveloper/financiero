generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String               @id @default(uuid())
  email              String               @unique
  passwordHash       String
  emailVerifiedAt    DateTime?
  subscriptionStatus   String               @default("trial")
  trialEndsAt          DateTime?
  subscriptionEndsAt   DateTime?
  subscriptionStartedAt DateTime?
  createdAt          DateTime             @default(now())
  transactions       Transaction[]
  installmentPlans   InstallmentPlan[]
  investmentEntries  InvestmentEntry[]
  savingsBoxes       SavingsBox[]
  plannedExpenses    PlannedExpense[]
  passwordResets     PasswordResetToken[]
}

model RedeemedVoucher {
  code       String   @id
  userId     String
  redeemedAt DateTime @default(now())
}

/// Código único gerado e enviado por e-mail após confirmação do PIX
model IssuedSubscriptionCode {
  code              String    @id
  email             String
  days              Int
  issuedAt          DateTime  @default(now())
  redeemedAt        DateTime?
  redeemedByUserId  String?
}

/// Cliente avisa que já pagou; admin envia o código por e-mail
model VoucherCodeRequest {
  id                  String    @id @default(uuid())
  userId              String
  email               String
  status              String    @default("pending")
  approveToken        String?   @unique
  expectedAmountCents Int?
  createdAt           DateTime  @default(now())
  fulfilledAt         DateTime?
}

model PendingRegistration {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  codeHash     String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SavingsBox {
  id        String   @id @default(uuid())
  userId    String
  name      String
  balance   Decimal  @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PlannedExpense {
  id          String   @id @default(uuid())
  userId      String
  description String
  amount      Decimal
  category    String
  dayOfMonth  Int
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Transaction {
  id                  String           @id @default(uuid())
  userId              String
  type                String
  amount              Decimal
  description         String
  category            String
  date                DateTime
  createdAt           DateTime         @default(now())
  installmentPlanId String?
  installmentNumber Int?
  installmentOf     Int?

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  installmentPlan InstallmentPlan?  @relation(fields: [installmentPlanId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
}

model InstallmentPlan {
  id                 String          @id @default(uuid())
  userId             String
  description        String
  category           String
  totalInstallments  Int
  installmentAmount  Decimal
  firstDueDate       DateTime
  createdAt          DateTime        @default(now())

  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedTransactions  Transaction[]

  @@index([userId])
}

model InvestmentEntry {
  id         String   @id @default(uuid())
  userId     String
  kind       String
  amount     Decimal
  date       DateTime
  assetName  String
  notes      String
  createdAt  DateTime @default(now())
  assetType  String   @default("Ações")
  quantity   Decimal?
  unitPrice  Decimal?
  otherCosts Decimal  @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
